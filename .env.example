# ============================================
# ChainOrchestra — Environment Configuration
# ============================================
# Copy to .env and fill in real values:
#   cp .env.example .env

# --- Gemini (LLM for MCP Orchestrator) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- JWT Auth ---
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Admin Seed User ---
# Use a strong password (e.g. openssl rand -base64 18). Do NOT keep the default in any non-local environment.
ADMIN_EMAIL=admin@chainorchestra.local
ADMIN_PASSWORD=change_me_to_a_strong_password

# --- Local PostgreSQL (Docker) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chainorchestra
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- NATS ---
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# --- Service Ports ---
GATEWAY_PORT=8080
USER_SERVICE_PORT=8001
ORDER_SERVICE_PORT=8002
INVENTORY_SERVICE_PORT=8003
LOGISTICS_SERVICE_PORT=8004
ANALYTICS_SERVICE_PORT=8005
NOTIFICATION_SERVICE_PORT=8006
MCP_HOST_PORT=8090
FRONTEND_PORT=3000

# --- Application ---
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# --- MCP Host ---
TOOL_TIMEOUT=30
RETRY_MAX_ATTEMPTS=3
SESSION_TTL=1800
MAX_TOOL_ROUNDS=10

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
