        },
        {
          "expr": "sum(rate(chainorchestra_inventory_service_http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "inventory-service",
          "refId": "D"
        },
        {
          "expr": "sum(rate(chainorchestra_logistics_service_http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "logistics-service",
          "refId": "E"
        },
        {
          "expr": "sum(rate(chainorchestra_analytics_service_http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "analytics-service",
          "refId": "F"
        },
        {
          "expr": "sum(rate(chainorchestra_notification_service_http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
