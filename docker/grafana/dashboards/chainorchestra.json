        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(chainorchestra_api_gateway_http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "api-gateway",
          "refId": "A"
        },
        {
          "expr": "sum(rate(chainorchestra_user_service_http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "user-service",
          "refId": "B"
        },
        {
          "expr": "sum(rate(chainorchestra_order_service_http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "order-service",
