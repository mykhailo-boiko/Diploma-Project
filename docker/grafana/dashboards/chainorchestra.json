  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s) per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(chainorchestra_api_gateway_http_requests_total[5m])) or vector(0)",
          "legendFormat": "api-gateway",
          "refId": "A"
        },
        {
          "expr": "sum(rate(chainorchestra_user_service_http_requests_total[5m])) or vector(0)",
          "legendFormat": "user-service",
          "refId": "B"
        },
        {
          "expr": "sum(rate(chainorchestra_order_service_http_requests_total[5m])) or vector(0)",
          "legendFormat": "order-service",
          "refId": "C"
        },
        {
          "expr": "sum(rate(chainorchestra_inventory_service_http_requests_total[5m])) or vector(0)",
          "legendFormat": "inventory-service",
          "refId": "D"
        },
        {
          "expr": "sum(rate(chainorchestra_logistics_service_http_requests_total[5m])) or vector(0)",
          "legendFormat": "logistics-service",
          "refId": "E"
        },
        {
          "expr": "sum(rate(chainorchestra_analytics_service_http_requests_total[5m])) or vector(0)",
          "legendFormat": "analytics-service",
          "refId": "F"
