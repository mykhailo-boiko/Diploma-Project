          "legendFormat": "inventory-service",
          "refId": "D"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(chainorchestra_logistics_service_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "logistics-service",
          "refId": "E"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(chainorchestra_analytics_service_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "analytics-service",
          "refId": "F"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(chainorchestra_notification_service_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "notification-service",
          "refId": "G"
        }
      ]
    },
